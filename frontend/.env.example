# Required — OpenAI API key for all AI features (GPT-4o)
OPENAI_API_KEY=sk-your-key-here

# Optional — API base URL (leave empty to use built-in Next.js API routes)
# NEXT_PUBLIC_API_URL=

# Required for shareable profiles — Upstash Redis (Vercel KV)
# Create a free store at https://console.upstash.com or via Vercel Marketplace
KV_REST_API_URL=https://your-store.upstash.io
KV_REST_API_TOKEN=your-token-here
